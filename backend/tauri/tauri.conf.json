{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Canopy",
  "version": "0.1.0",
  "identifier": "com.canopy.app",
  "build": {
    "beforeDevCommand": "cargo build --manifest-path backend/mcp/Cargo.toml && cd apps/desktop && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cargo build --release --manifest-path backend/mcp/Cargo.toml && cd apps/desktop && bun run build",
    "frontendDist": "../../apps/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Canopy",
        "width": 1200,
        "height": 800,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 24 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png", "icons/128x128@2x.png", "icons/128x128.png", "icons/32x32.png"],
    "resources": {
      "sounds/*": "sounds/"
    }
  }
}
