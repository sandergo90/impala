{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/v2/crates/tauri-cli/schema.json",
  "productName": "Differ",
  "version": "0.1.0",
  "identifier": "com.differ.app",
  "build": {
    "beforeDevCommand": "cd apps/desktop && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd apps/desktop && bun run build",
    "frontendDist": "../../apps/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Differ",
        "width": 1200,
        "height": 800,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "icon": "icons/icon.png"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png", "icons/128x128@2x.png", "icons/128x128.png", "icons/32x32.png"]
  }
}
