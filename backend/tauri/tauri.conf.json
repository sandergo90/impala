{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Impala",
  "version": "0.5.3",
  "identifier": "be.kodeus.impala",
  "build": {
    "beforeDevCommand": "bash scripts/build-mcp-sidecar.sh debug && bash scripts/build-pty-daemon-sidecar.sh debug && cd apps/desktop && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash scripts/build-mcp-sidecar.sh release && bash scripts/build-pty-daemon-sidecar.sh release && cd apps/desktop && bun run build",
    "frontendDist": "../../apps/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Impala",
        "width": 1200,
        "height": 800,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 30
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/128x128@2x.png",
      "icons/128x128.png",
      "icons/32x32.png"
    ],
    "resources": {
      "sounds/*": "sounds/"
    },
    "externalBin": [
      "binaries/impala-mcp",
      "binaries/impala-pty-daemon"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3MTY5MDEyRDVDOERDRQpSV1RPalZ3dEFXbHhEeExySFpJY01nQWJFR2VHTjUwM1Z5em80S3RpR2t5ZEtaUWcwYkZVdlZnQwo=",
      "endpoints": [
        "https://github.com/sandergo90/impala/releases/latest/download/latest.json"
      ]
    }
  }
}
