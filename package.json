{
  "name": "impala",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bunx tauri dev",
    "build": "export $(grep -v '^#' .env | xargs) && bunx tauri build",
    "build:debug": "export $(grep -v '^#' .env | xargs) && bunx tauri build --features devtools",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "2.8.20"
  }
}
