{
  "name": "impala",
  "private": true,
  "packageManager": "bun@1.2.10",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bunx tauri dev",
    "build": "export $(grep -v '^#' .env | xargs) && bunx tauri build",
    "build:debug": "export $(grep -v '^#' .env | xargs) && bunx tauri build --features devtools",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "2.8.20"
  },
  "patchedDependencies": {
    "@pierre/diffs@1.1.7": "patches/@pierre%2Fdiffs@1.1.7.patch"
  }
}
